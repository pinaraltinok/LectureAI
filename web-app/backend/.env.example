# ==============================================================
# LectureAI Backend Service Environment Variables
# Copy this file to .env and fill in your values.
# ==============================================================

# --- Database ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/lectureai"

# --- JWT ---
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="24h"

# --- Server ---
PORT=3001
NODE_ENV=development

# --- Upload ---
UPLOAD_DIR=./uploads
