# ==============================================================
# Environment variables for BitirmeCV-StT audio + orchestrator
# Copy to `scripts/.env` (recommended) or repo `.env`. Never commit secrets.
# `python -m scripts.run_pipeline` loads `scripts/.env` then `.env` via
# python-dotenv (see `src/env_bootstrap.py`).
# ==============================================================

# --- Google Cloud Storage: one bucket per data type -----------
# europe-west4
# Pipeline video discovery scans this bucket/prefix:
GCS_FULL_VIDEOS_BUCKET=lectureai_full_videos
GCS_BUCKET_VIDEOS=lectureai_full_videos
GCS_BUCKET_PROCESSED=lectureai_processed
# multi-region US
GCS_BUCKET_TRANSCRIPTS=lectureai_transcripts
GCS_BUCKET_AUDIO=lectureai_audio
GCS_BUCKET_STUDENT_AUDIOS=lectureai_student_audios
# optional (only if you decide to persist per-chunk mp3s)
GCS_BUCKET_AUDIO_CHUNKS=lectureai_audio_chunks

# --- Object key overrides (optional) ---
# Defaults are fine for the standard layout; override only when
# the CV/CI pipeline writes to different paths.
# GCS_KEY_VIDEO=Lesson_Records/{video_id}.mp4
# GCS_KEY_CV=results/{video_id}.json
# GCS_KEY_AUDIO_JSON={video_id}.json
# GCS_KEY_REPORT=reports/{video_id}.json
# GCS_KEY_MP3={video_id}.mp3
# Audio pipeline writes under the processed bucket:
# GCS_KEY_PROCESSED_AUDIO_JSON=data/audio/{video_id}.json
# GCS_KEY_PROCESSED_TRANSCRIPT_TXT=transcripts/{video_id}.txt

# --- GCP credentials ---
GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\service-account.json
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Audio: MP4 is downloaded from GCS, converted to MP3 with ffmpeg
# (install ffmpeg and add to PATH), then uploaded to AssemblyAI.
# Windows: if you see WinError 2, set the full path to ffmpeg.exe:
# FFMPEG_BINARY=C:\path\to\ffmpeg\bin\ffmpeg.exe

# --- AssemblyAI ---
ASSEMBLYAI_API_KEY=your-assemblyai-api-key

# --- Gemini ---
GEMINI_API_KEY=your-gemini-api-key

# --- Processing config ---
CHUNK_MINUTES=30

# --- CV (Cloud Run cv-worker → Modal HTTP) ---
# Modal deploy prints the run_trigger URL; set the same bearer as Modal secret AUTH_TOKEN.
MODAL_CV_WEBHOOK_URL=https://YOUR_WORKSPACE--lectureai-cv-run-trigger.modal.run
MODAL_CV_WEBHOOK_BEARER=your-modal-auth-token
CV_TEACHER_NAME=Teacher

# CV reads raw video from GCS (override if layout differs)
# GCS_FULL_VIDEOS_BUCKET=lectureai_full_videos
# CV_GCS_VIDEO_PREFIX=Lesson_Records
# GCS_BUCKET_PROCESSED=lectureai_processed
# CV_GCS_RESULTS_PREFIX=results

# Gülümseme eşiği (``video/face_metrics`` heuristik skoru; 0.35 çoğu yüzde çok düşük — 0.55–0.65 dene)
# CV_SMILE_THRESHOLD=0.35

# Optional: screen-share heuristics (``video/screen_share_detector``); calibrate on real Zoom/Teams recordings
# CV_SCREEN_SHARE_SMALL_TILE_RATIO=0.045
# CV_SCREEN_SHARE_FRAME_CHANGE_THRESH=0.085
# CV_SCREEN_SHARE_TEACHER_MOVEMENT_LOW=0.14
# CV_SCREEN_SHARE_MIN_SIGNALS=2
# CV_SCREEN_SHARE_LAPLACIAN_VAR_HIGH=280
# CV_SCREEN_SHARE_SLIDE_BRIGHTNESS_MIN=158
# CV_SCREEN_SHARE_SLIDE_STD_MAX=48

# Modal secret ``lectureai-gcp`` (dashboard): GCP_SA_JSON or SERVICE_ACCOUNT_JSON,
# GOOGLE_CLOUD_PROJECT, AUTH_TOKEN, and optionally the GCS_* / CV_GCS_* keys above.

# --- Backend pipeline timeline (HTTP webhook from workers) -----------------
# Workers POST JSON: {"video_id","stage","status","detail"} to this URL.
# Example path (your Node API): /api/pipeline/worker-events
# BACKEND_STATUS_WEBHOOK=https://YOUR_API_HOST/api/pipeline/worker-events
# Same secret the backend validates as Authorization: Bearer ... (do not commit real value).
# BACKEND_STATUS_WEBHOOK_BEARER=generate-a-long-random-secret
